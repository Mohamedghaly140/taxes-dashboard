{
  "name": "taxes-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bun run --bun next dev",
    "build": "bun run --bun next build",
    "start": "bun run --bun next start",
    "lint": "eslint",
    "postinstall": "bun --bun run prisma generate",
    "prisma:push": "bun --bun run prisma db push",
    "prisma:generate": "bun --bun run prisma generate",
    "prisma:migrate": "bun --bun run prisma migrate dev",
    "prisma:migrate:reset": "bun --bun run prisma migrate reset",
    "prisma:studio": "bun --bun run prisma studio",
    "prisma:validate": "bun --bun run prisma validate",
    "prisma:seed": "bun --bun run prisma db seed"
  },
  "dependencies": {
    "@lucia-auth/adapter-prisma": "^4.0.1",
    "@node-rs/argon2": "^2.0.2",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucia": "^3.2.2",
    "lucide-react": "^1.7.0",
    "next": "16.2.1",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.1.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bun": "^1.3.11",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "prisma": "^7.6.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
